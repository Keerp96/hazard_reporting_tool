<% content_for(:title, "QR Codes - HazardTracker") %>

<h1 class="h3 mb-4">Location QR Codes</h1>
<p class="text-muted mb-4">Print these QR codes and post them at each location. When scanned, they open a pre-filled hazard report form for that location.</p>

<div class="row g-4">
  <% @locations.each do |location| %>
    <div class="col-md-4 col-sm-6">
      <div class="card border-0 shadow-sm text-center h-100">
        <div class="card-body">
          <h5 class="card-title"><%= location.name %></h5>
          <p class="text-muted small">Code: <%= location.code %></p>
          <%
            qr_url = new_report_url(location: location.name)
            qr = RQRCode::QRCode.new(qr_url)
            svg = qr.as_svg(color: "000", shape_rendering: "crispEdges", module_size: 4, standalone: false, use_path: true)
          %>
          <div class="mb-3"><%= raw svg %></div>
          <div class="d-grid gap-2">
            <%= link_to "Download SVG", qr_code_location_path(location, format: :svg), class: "btn btn-outline-primary btn-sm" %>
            <%= link_to "Test Link", new_report_path(location: location.name), class: "btn btn-outline-secondary btn-sm" %>
          </div>
        </div>
      </div>
    </div>
  <% end %>
</div>
