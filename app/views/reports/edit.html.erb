<% content_for(:title, "Edit Report - HazardTracker") %>

<div class="row justify-content-center">
  <div class="col-lg-8">
    <div class="mb-4">
      <%= link_to "← Back to Report", report_path(@report), class: "text-decoration-none" %>
    </div>
    <div class="card border-0 shadow-sm">
      <div class="card-header bg-white">
        <h4 class="mb-0">Edit Hazard Report #<%= @report.id %></h4>
      </div>
      <div class="card-body">
        <%= render "form", report: @report, locations: @locations %>
      </div>
    </div>
  </div>
</div>
