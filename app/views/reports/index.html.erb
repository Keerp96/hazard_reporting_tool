<% content_for(:title, "All Reports - HazardTracker") %>

<div class="d-flex justify-content-between align-items-center mb-4">
  <h1 class="h3 mb-0">Hazard Reports</h1>
  <div>
    <%= link_to "Export CSV", export_csv_reports_path(q: params[:q]), class: "btn btn-outline-secondary me-2" %>
    <%= link_to "New Report", new_report_path, class: "btn btn-primary" %>
  </div>
</div>

<!-- Filters -->
<div class="card border-0 shadow-sm mb-4">
  <div class="card-body">
    <%= search_form_for @q, url: reports_path, html: { class: "row g-3 align-items-end", data: { controller: "filter", action: "change->filter#submit" } } do |f| %>
      <div class="col-md-3">
        <%= f.label :title_or_description_cont, "Search", class: "form-label" %>
        <%= f.search_field :title_or_description_cont, class: "form-control", placeholder: "Search by title or description..." %>
      </div>
      <div class="col-md-2">
        <%= f.label :severity_eq, "Severity", class: "form-label" %>
        <%= f.select :severity_eq, Report.severities.keys.map { |s| [s.titleize, Report.severities[s]] }, { include_blank: "All" }, class: "form-select" %>
      </div>
      <div class="col-md-2">
        <%= f.label :status_eq, "Status", class: "form-label" %>
        <%= f.select :status_eq, Report.statuses.keys.map { |s| [s.titleize, Report.statuses[s]] }, { include_blank: "All" }, class: "form-select" %>
      </div>
      <div class="col-md-2">
        <%= f.label :location_eq, "Location", class: "form-label" %>
        <%= f.select :location_eq, @locations.pluck(:name), { include_blank: "All" }, class: "form-select" %>
      </div>
      <div class="col-md-3">
        <div class="d-flex gap-2">
          <%= f.submit "Filter", class: "btn btn-primary" %>
          <%= link_to "Clear", reports_path, class: "btn btn-outline-secondary" %>
        </div>
      </div>
    <% end %>
  </div>
</div>

<!-- Reports Table -->
<div class="card border-0 shadow-sm">
  <div class="card-body p-0">
    <div class="table-responsive">
      <table class="table table-hover mb-0">
        <thead class="table-light">
          <tr>
            <th><%= sort_link(@q, :id, "#") %></th>
            <th><%= sort_link(@q, :title, "Title") %></th>
            <th><%= sort_link(@q, :severity, "Severity") %></th>
            <th><%= sort_link(@q, :status, "Status") %></th>
            <th>Reporter</th>
            <th>Assignee</th>
            <th><%= sort_link(@q, :reported_at, "Date") %></th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% @reports.each do |report| %>
            <tr>
              <td><%= report.id %></td>
              <td>
                <%= link_to report.title, report_path(report), class: "text-decoration-none fw-semibold" %>
              </td>
              <td><span class="badge bg-<%= report.severity_color %>"><%= report.severity.titleize %></span></td>
              <td><span class="badge bg-<%= report.status_color %>"><%= report.status.titleize %></span></td>
              <td><%= report.reporter.full_name %></td>
              <td><%= report.assignee&.full_name || tag.span("Unassigned", class: "text-muted") %></td>
              <td><%= report.reported_at.strftime("%b %d, %Y") %></td>
              <td>
                <%= link_to "View", report_path(report), class: "btn btn-outline-primary btn-sm" %>
              </td>
            </tr>
          <% end %>
          <% if @reports.empty? %>
            <tr><td colspan="8" class="text-center text-muted py-4">No reports found.</td></tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
  <% if @reports.total_pages.to_i > 1 %>
    <div class="card-footer bg-white">
      <%= paginate @reports, theme: 'bootstrap-5' %>
    </div>
  <% end %>
</div>
