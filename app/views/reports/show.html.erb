<% content_for(:title, "#{@report.title} - HazardTracker") %>

<div class="mb-4">
  <%= link_to "← Back to Reports", reports_path, class: "text-decoration-none" %>
</div>

<div class="row g-4">
  <!-- Main Content -->
  <div class="col-lg-8">
    <div class="card border-0 shadow-sm mb-4">
      <div class="card-header bg-white d-flex justify-content-between align-items-center">
        <h4 class="mb-0"><%= @report.title %></h4>
        <div>
          <span class="badge bg-<%= @report.severity_color %> me-1"><%= @report.severity.titleize %></span>
          <span class="badge bg-<%= @report.status_color %>"><%= @report.status.titleize %></span>
        </div>
      </div>
      <div class="card-body">
        <div class="row mb-3">
          <div class="col-sm-6">
            <small class="text-muted">Location</small>
            <p class="fw-semibold mb-0"><%= @report.location %></p>
          </div>
          <div class="col-sm-6">
            <small class="text-muted">Reported At</small>
            <p class="fw-semibold mb-0"><%= @report.reported_at.strftime("%B %d, %Y at %H:%M") %></p>
          </div>
        </div>
        <div class="row mb-3">
          <div class="col-sm-6">
            <small class="text-muted">Reporter</small>
            <p class="fw-semibold mb-0"><%= @report.reporter.full_name %></p>
          </div>
          <div class="col-sm-6">
            <small class="text-muted">Assignee</small>
            <p class="fw-semibold mb-0"><%= @report.assignee&.full_name || "Unassigned" %></p>
          </div>
        </div>
        <hr>
        <h6>Description</h6>
        <p class="text-break"><%= simple_format(@report.description) %></p>

        <% if @report.photo.attached? %>
          <h6>Photo Evidence</h6>
          <div class="mb-3">
            <%= image_tag @report.photo, class: "img-fluid rounded", style: "max-height: 400px;" %>
          </div>
        <% end %>
      </div>
    </div>

    <!-- Comments Section -->
    <div class="card border-0 shadow-sm">
      <div class="card-header bg-white">
        <h5 class="mb-0">Comments (<%= @comments.count %>)</h5>
      </div>
      <div class="card-body">
        <div id="comments">
          <% @comments.each do |comment| %>
            <%= render partial: "comments/comment", locals: { comment: comment } %>
          <% end %>
          <% if @comments.empty? %>
            <p class="text-muted" id="no-comments">No comments yet.</p>
          <% end %>
        </div>

        <hr>
        <div id="comment_form">
          <%= render partial: "comments/form", locals: { report: @report, comment: @comment } %>
        </div>
      </div>
    </div>
  </div>

  <!-- Sidebar -->
  <div class="col-lg-4">
    <!-- Actions Card -->
    <div class="card border-0 shadow-sm mb-4">
      <div class="card-header bg-white">
        <h6 class="mb-0">Actions</h6>
      </div>
      <div class="card-body d-grid gap-2">
        <%= link_to "Download PDF", download_pdf_report_path(@report), class: "btn btn-outline-secondary btn-sm" %>

        <% if current_user.supervisor? %>
          <%= link_to "Edit Report", edit_report_path(@report), class: "btn btn-outline-primary btn-sm" %>

          <% if @report.open? %>
            <hr>
            <h6 class="text-muted small">Assign To</h6>
            <%= form_with url: assign_report_path(@report), method: :patch, class: "d-flex gap-2" do |f| %>
              <%= f.select :assignee_id, User.all.map { |u| ["#{u.full_name} (#{u.role.titleize})", u.id] }, { prompt: "Select user..." }, class: "form-select form-select-sm" %>
              <%= f.submit "Assign", class: "btn btn-info btn-sm" %>
            <% end %>
          <% end %>

          <% if @report.may_start_work? %>
            <%= button_to "Start Work", start_work_report_path(@report), method: :patch, class: "btn btn-warning btn-sm" %>
          <% end %>

          <% if @report.may_resolve? %>
            <%= button_to "Mark Resolved", resolve_report_path(@report), method: :patch, class: "btn btn-success btn-sm" %>
          <% end %>

          <% if @report.may_close? %>
            <%= button_to "Close Report", close_report_path(@report), method: :patch, class: "btn btn-secondary btn-sm" %>
          <% end %>

          <% if @report.may_reopen? %>
            <%= button_to "Reopen Report", reopen_report_path(@report), method: :patch, class: "btn btn-outline-warning btn-sm" %>
          <% end %>

          <hr>
          <%= button_to "Delete Report", report_path(@report), method: :delete, class: "btn btn-outline-danger btn-sm", data: { turbo_confirm: "Are you sure you want to delete this report?" } %>
        <% end %>
      </div>
    </div>

    <!-- Timeline Card -->
    <div class="card border-0 shadow-sm">
      <div class="card-header bg-white">
        <h6 class="mb-0">Timeline</h6>
      </div>
      <div class="card-body">
        <div class="d-flex align-items-center mb-2">
          <span class="badge bg-primary rounded-pill me-2">1</span>
          <small>Created on <%= @report.created_at.strftime("%b %d, %Y %H:%M") %></small>
        </div>
        <% if @report.assignee.present? %>
          <div class="d-flex align-items-center mb-2">
            <span class="badge bg-info rounded-pill me-2">2</span>
            <small>Assigned to <%= @report.assignee.full_name %></small>
          </div>
        <% end %>
        <% if @report.resolved? || @report.closed? %>
          <div class="d-flex align-items-center mb-2">
            <span class="badge bg-success rounded-pill me-2">3</span>
            <small>Resolved on <%= @report.updated_at.strftime("%b %d, %Y %H:%M") %></small>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
