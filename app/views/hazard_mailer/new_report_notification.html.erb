<h2>New Hazard Report Submitted</h2>

<p>A new hazard has been reported and requires attention:</p>

<table>
  <tr><td><strong>Title:</strong></td><td><%= @report.title %></td></tr>
  <tr><td><strong>Location:</strong></td><td><%= @report.location %></td></tr>
  <tr><td><strong>Severity:</strong></td><td><%= @report.severity.titleize %></td></tr>
  <tr><td><strong>Reporter:</strong></td><td><%= @report.reporter.full_name %></td></tr>
  <tr><td><strong>Reported At:</strong></td><td><%= @report.reported_at.strftime("%B %d, %Y %H:%M") %></td></tr>
</table>

<p><strong>Description:</strong></p>
<p><%= @report.description %></p>

<p><%= link_to "View Report", report_url(@report) %></p>
