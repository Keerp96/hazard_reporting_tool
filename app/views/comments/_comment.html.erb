<%= turbo_frame_tag comment do %>
  <div class="d-flex mb-3" id="<%= dom_id(comment) %>">
    <div class="flex-shrink-0">
      <div class="rounded-circle bg-secondary text-white d-flex align-items-center justify-content-center" style="width: 35px; height: 35px;">
        <%= comment.user.first_name[0].upcase %><%= comment.user.last_name[0].upcase %>
      </div>
    </div>
    <div class="flex-grow-1 ms-3">
      <div class="d-flex justify-content-between align-items-start">
        <div>
          <strong><%= comment.user.full_name %></strong>
          <small class="text-muted ms-2"><%= time_ago_in_words(comment.created_at) %> ago</small>
        </div>
        <% if current_user == comment.user || current_user.supervisor? %>
          <%= button_to "×", report_comment_path(comment.report, comment), method: :delete, class: "btn btn-sm btn-outline-danger", data: { turbo_confirm: "Delete this comment?" } %>
        <% end %>
      </div>
      <p class="mb-0 mt-1"><%= simple_format(comment.body) %></p>
    </div>
  </div>
<% end %>
